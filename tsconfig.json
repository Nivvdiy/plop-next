{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "types": ["node"],
    "module": "esnext",
    "lib": [
      "ESNext"
    ],
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noEmit": true,
    "target": "es2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist"
  }
}
