{
  "name": "@plop-next/cli",
  "version": "0.1.3",
  "description": "Micro-generator framework CLI",
  "homepage": "https://github.com/Nivvdiy/plop-next",
  "bugs": {
    "url": "https://github.com/Nivvdiy/plop-next/issues"
  },
  "license": "MIT",
  "author": "Nivvdiy <nivvdiy@gmail.com>",
  "files": [
    "dist"
  ],
  "bin": {
    "plop-next": "./dist/cli.js"
  },
  "repository": {
    "directory": "packages/cli",
    "type": "git",
    "url": "https://github.com/Nivvdiy/plop-next.git"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
    "prepublishOnly": "yarn build",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@plop-next/core": "workspace:*",
    "interpret": "^3.1.1",
    "liftoff": "^5.0.1",
    "nanospinner": "^1.2.2",
    "picocolors": "^1.1.1",
    "v8flags": "^4.0.1"
  },
  "devDependencies": {
    "@types/interpret": "^1.1.4",
    "@types/liftoff": "^4.0.3",
    "@types/v8flags": "^3.1.3",
    "execa": "^9.6.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": "./dist/cli.js"
  }
}
