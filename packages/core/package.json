{
  "name": "@plop-next/core",
  "version": "0.1.2",
  "description": "Core utilities and types for plop-next",
  "bugs": {
    "url": "https://github.com/Nivvdiy/plop-next/issues"
  },
  "license": "MIT",
  "author": "Nivvdiy <nivvdiy@gmail.com>",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "repository": {
    "directory": "packages/core",
    "type": "git",
    "url": "https://github.com/Nivvdiy/plop-next.git"
  },
  "publishConfig": {
