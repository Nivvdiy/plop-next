    "test": "vitest run && tsc --noEmit",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "change-case": "^5.4.4",
    "dlv": "^1.1.3",
    "handlebars": "^4.7.9",
    "resolve": "^1.22.11",
    "tinyglobby": "^0.2.15",
    "title-case": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
