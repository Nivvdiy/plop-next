{
  "name": "plop-next",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "dev": "node packages/cli/dist/cli.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky install",
    "plop-next": "node packages/cli/dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nivvdiy/plop-next.git"
  },
  "bugs": {
    "url": "https://github.com/nivvdiy/plop-next/issues"
  },
  "homepage": "https://github.com/nivvdiy/plop-next",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.13.0",
  "devDependencies": {
    "@bartheleway/inquirer-table-multiple": "^1.0.3",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@plop-next/cli": "workspace:^",
    "@plop-next/i18n": "workspace:^",
    "@types/node": "^25.5.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "yarn": "^1.22.22"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --cache --fix",
      "prettier --write"
    ]
  }
}
